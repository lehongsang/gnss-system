# App
APP_PORT=3000
APP_NAME=GNSS System
NODE_ENV=production
LOG_LEVEL=info
FRONTEND_URL=https://your-frontend.example.com
CORS_ORIGINS=https://your-frontend.example.com
WS_CORS_ORIGIN=https://your-frontend.example.com
SWAGGER_ENABLED=false
GENERATE_OPENAPI=false

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5433
POSTGRES_USERNAME=gnss
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=gnss_system
POSTGRES_SSL=false

# Redis
REDIS_PASSWORD=change-me-redis-password
REDIS_PORT=6379
REDIS_URL=redis://:change-me-redis-password@redis:6379

# Auth
BETTER_AUTH_BASE_URL=https://your-api.example.com/api/auth
BETTER_AUTH_SECRET=change-me-generate-with-task-gen-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM="GNSS System <no-reply@example.com>"
MAIL_SECURE=false

# Default Admin Account
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password

# Kafka / Redpanda
KAFKA_HOST=redpanda
KAFKA_PORT=9092
KAFKA_ADVERTISED_HOST=localhost
KAFKA_CLIENT_ID=gnss-system
KAFKA_UI_PORT=8088

# S3 Storage (SeaweedFS)
SEAWEEDFS_VOLUME_PORT=8080
SEAWEEDFS_FILER_PORT=8888
SEAWEEDFS_FILER_S3_PORT=8333
S3_ENDPOINT=http://seaweedfs:8333
S3_EXTERNAL_URL=https://your-api.example.com/s3
S3_REGION=us-east-1
S3_ACCESS_KEY=change-me-s3-access-key
S3_SECRET_KEY=change-me-s3-secret-key
S3_BUCKET=medias
S3_FORCE_PATH_STYLE=true

# MQTT / EMQX
MQTT_HOST=emqx
MQTT_PORT=1883
MQTT_CLIENT_ID=gnss-gateway
MQTT_USERNAME=gnss-gateway
MQTT_PASSWORD=change-me-mqtt-password
MQTT_PROTOCOL=mqtt
MQTT_PUBLIC_HOST=your-api.example.com
MQTT_PUBLIC_PORT=1883
MQTT_PUBLIC_PROTOCOL=mqtt
EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=change-me-emqx-dashboard-password

# MediaMTX
MEDIAMTX_API_URL=http://mediamtx:9997
MEDIAMTX_WEBRTC_BASE_URL=https://your-api.example.com/webrtc
MEDIAMTX_RTSP_PORT=8554
MEDIAMTX_WEBRTC_PORT=8889
MEDIAMTX_API_PORT=9997

# Route Planning
ROUTING_PROVIDER=mapbox
MAPBOX_ACCESS_TOKEN=
MAPBOX_DIRECTIONS_PROFILE=mapbox/driving
ROUTE_DEVIATION_DEFAULT_THRESHOLD_METERS=50
ROUTE_DEVIATION_COOLDOWN_SECONDS=300
DASHBOARD_MEDIA_TOTAL_BYTES=5368709120

# Optional image pins
POSTGIS_IMAGE=postgis/postgis:17-3.5
MEDIAMTX_IMAGE=bluenviron/mediamtx:latest
KAFKA_UI_IMAGE=provectuslabs/kafka-ui:latest
